{
  "name": "pullup-map-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create pullup-map-db",
    "db:init": "wrangler d1 execute pullup-map-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute pullup-map-db --remote --file=schema.sql",
    "r2:create": "wrangler r2 bucket create pullup-map-images"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.98.0"
  }
}
